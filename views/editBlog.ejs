<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
  </head>
  <body>
    <%- include('./partials/nav.ejs') %>

    <div class="container mt-4">
      <div class="section-label"><span>Edit Your Story</span></div>
      
      <div class="card edit-blog-card p-4">
        <form action="/blog/edit/<%= blog._id %>" method="POST" enctype="multipart/form-data">
          <div class="mb-4">
            <label for="title" class="form-label">Blog Title</label>
            <input type="text" class="form-control" id="title" name="title" value="<%= blog.title %>" required>
          </div>

          <div class="mb-4">
            <label for="body" class="form-label">Blog Content</label>
            <textarea class="form-control" id="body" name="body" style="height: 300px" required><%= blog.body %></textarea>
          </div>

          <div class="mb-4">
            <label class="form-label">Current Cover Image</label>
            <div class="current-image-preview mb-2">
              <% if (blog.coverImage) { %>
                <img src="<%= blog.coverImage %>" alt="Current Cover" class="img-thumbnail" style="max-height: 150px">
              <% } else { %>
                <p class="text-muted">No image uploaded</p>
              <% } %>
            </div>
            <label for="coverImage" class="form-label">Change Cover Image (Optional)</label>
            <input class="form-control" type="file" id="coverImage" name="coverImage">
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Update Blog</button>
            <a href="/profile" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>

    <%- include('./partials/footer.ejs') %>
    <%- include('./partials/script.ejs') %>
  </body>
</html>
