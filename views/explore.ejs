<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
  </head>
  <body>
     <%- include('./partials/nav.ejs') %>

    <!-- Search Hero -->
    <section class="explore-hero">
      <div class="explore-hero-inner">
        <span class="explore-badge">✦ Discover Stories</span>
        <h1 class="explore-title">Explore <em>all blogs</em></h1>
        <p class="explore-sub">Search through our collection of stories, ideas, and insights from creators around the world.</p>
        <form class="explore-search-form" action="/explore" method="GET" id="searchForm">
          <div class="explore-search-wrapper">
            <svg class="explore-search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="text" name="q" placeholder="Search blogs by title..." value="<%= typeof query !== 'undefined' ? query : '' %>" class="explore-search-input" id="searchInput" autocomplete="off">
            <button type="submit" class="explore-search-btn">Search</button>
          </div>
        </form>
      </div>
    </section>

    <!-- Results -->
    <div class="container">
      <% if (typeof query !== 'undefined' && query) { %>
        <div class="explore-results-info">
          <span class="results-count"><%= Blogs.length %> result<%= Blogs.length !== 1 ? 's' : '' %></span>
          <span class="results-query">for "<strong><%= query %></strong>"</span>
          <a href="/explore" class="results-clear">Clear search</a>
        </div>
      <% } else { %>
        <div class="section-label"><span>All Blogs</span></div>
      <% } %>

      <% if (Blogs.length === 0) { %>
        <div class="explore-empty">
          <div class="explore-empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></svg>
          </div>
          <h3>No blogs found</h3>
          <p>Try searching with different keywords or browse all blogs.</p>
          <a href="/explore" class="btn btn-primary">Browse all blogs</a>
        </div>
      <% } else { %>
        <div class="blog-grid explore-grid">
          <% Blogs.forEach((blog, index) => { %>
            <div class="card">
              <% if (blog.coverImage) { %>
                <img src="<%= blog.coverImage %>" class="card-img-top" alt="<%= blog.title %>">
              <% } else { %>
                <div class="card-img-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
              <% } %>
              <div class="card-body">
                <h5 class="card-title"><%= blog.title %></h5>
                <p class="card-text"><%= blog.body %></p>
                <% if (blog.createdAt) { %>
                  <div class="card-meta">
                    <span><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>
                <% } %>
                <a href="/blog/<%= blog._id %>" class="btn btn-primary">Read More</a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <%- include('./partials/footer.ejs') %>
    <%- include('./partials/script.ejs') %>
  </body>
</html>
