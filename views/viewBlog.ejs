<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
  </head>
  <body>
     <%- include('./partials/nav.ejs') %>

    <!-- Blog Article -->
    <article class="blog-article">
      <!-- Cover Image -->
      <div class="article-cover">
        <% if (blog.coverImage) { %>
          <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" class="article-cover-img">
        <% } else { %>
          <div class="article-cover-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          </div>
        <% } %>
      </div>

      <!-- Article Content -->
      <div class="article-content">
        <h1 class="article-title"><%= blog.title %></h1>

        <!-- Author Info -->
        <div class="article-author">
          <img src="<%= (blog.createdBy.profileImgUrl && !blog.createdBy.profileImgUrl.startsWith('images/')) ? blog.createdBy.profileImgUrl : 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + blog.createdBy.first_name %>" alt="<%= blog.createdBy.first_name %>" class="author-avatar">
          <div class="author-info">
            <span class="author-name"><%= blog.createdBy.first_name %></span>
            <% if (blog.createdAt) { %>
              <span class="article-date"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
            <% } %>
          </div>
        </div>

        <!-- Divider -->
        <div class="article-divider"></div>

        <!-- Body -->
        <div class="article-body">
          <%= blog.body %>
        </div>

        <!-- Divider -->
        <div class="article-divider"></div>

        <!-- Comments Section -->
        <section class="comments-section">
          <h2 class="comments-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
            Comments (<%= comments.length %>)
          </h2>

          <% if (locals.User) { %>
            <form action="/blog/comments/<%= blog._id %>" method="POST" class="comment-form">
              <div class="comment-input-wrapper">
                <img src="<%= (locals.User.profileImgUrl && !locals.User.profileImgUrl.startsWith('images/')) ? locals.User.profileImgUrl : 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + locals.User.first_name %>" alt="You" class="comment-avatar">
                <input type="text" 
                      class="comment-input" 
                      id="commentInput" 
                      placeholder="Write a comment..." 
                      name="title"
                      required>
              </div>
              <button type="submit" class="comment-submit-btn">Post Comment</button>
            </form>
          <% } else { %>
            <div class="comment-login-prompt">
              <p>Please <a href="/signin">sign in</a> to leave a comment.</p>
            </div>
          <% } %>

          <div class="comments-list">
            <% comments.forEach(comment => { %>
              <div class="comment-card">
                <img src="<%= (comment.createdBy.profileImgUrl && !comment.createdBy.profileImgUrl.startsWith('images/')) ? comment.createdBy.profileImgUrl : 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + comment.createdBy.first_name %>" alt="<%= comment.createdBy.first_name %>" class="comment-card-avatar">
                <div class="comment-card-content">
                  <div class="comment-card-header">
                    <span class="comment-card-name"><%= comment.createdBy.first_name %></span>
                    <% if (comment.createdAt) { %>
                      <span class="comment-card-time"><%= new Date(comment.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                    <% } %>
                  </div>
                  <p class="comment-card-text"><%= comment.title %></p>
                </div>
              </div>
            <% }) %>
          </div>
        </section>
      </div>
    </article>

    <%- include('./partials/footer.ejs') %>
    <%- include('./partials/script.ejs') %>
  </body>
</html>
