<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/head.ejs') %>

</head>

<body>
  <%- include('./partials/nav.ejs') %>
    <%- include('./partials/slide.ejs') %>

      <!-- ── MODERN 3D ABOUT DASHBOARD ────────────────────────── -->
      <section class="about-dashboard">
        <div class="container">
          <div class="dashboard-header text-center mb-5">
            <h2 class="display-4 fw-bold">Elevate Your <span>Craft</span></h2>
            <p class="text-muted">A workspace designed for modern creators.</p>
          </div>

          <div class="modern-3d-grid">
            <!-- Feature 1: Writing -->
            <div class="modern-3d-card card-writing anim-reveal" style="--delay: 0.1s">
              <div class="card-3d-inner">
                <div class="card-3d-front">
                  <div class="icon-wrap">✍️</div>
                  <h3>Distraction-Free Writing</h3>
                  <p>Focus on what matters most: your words. Our editor is built for flow.</p>
                </div>
                <div class="card-3d-back">
                  <p>Clean UI, Auto-save, and Markdown support.</p>
                  <a href="/blog" class="btn-cta-small">Start Now</a>
                </div>
              </div>
            </div>

            <!-- Feature 2: Analytics -->
            <div class="modern-3d-card card-analytics anim-reveal" style="--delay: 0.2s">
              <div class="card-3d-inner">
                <div class="card-3d-front">
                  <div class="icon-wrap">📊</div>
                  <h3>Real-time Impact</h3>
                  <p>Track how your stories resonate with readers across the globe.</p>
                </div>
                <div class="card-3d-back">
                  <p>Deep insights into reach and engagement.</p>
                  <a href="/profile" class="btn-cta-small">View Stats</a>
                </div>
              </div>
            </div>

            <!-- Feature 3: Community -->
            <div class="modern-3d-card card-community anim-reveal" style="--delay: 0.3s">
              <div class="card-3d-inner">
                <div class="card-3d-front">
                  <div class="icon-wrap">🌍</div>
                  <h3>Global Community</h3>
                  <p>Join a network of passionate writers and curious readers.</p>
                </div>
                <div class="card-3d-back">
                  <p>Follow, comment, and grow your audience.</p>
                  <a href="/explore" class="btn-cta-small">Explore</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom CTA -->
          <div class="dashboard-footer mt-5 text-center">
            <div class="glass-cta anim-reveal" style="--delay: 0.5s">
              <h4>Ready to share your vision?</h4>
              <p>Join Blogify today and start your journey.</p>
              <a href="/signup" class="hero-btn-primary">Create Your Blog</a>
            </div>
          </div>
        </div>
      </section>

      <style>
        .about-dashboard {
          padding: 80px 0;
          background: var(--bg);
          position: relative;
          overflow: hidden;
        }

        .dashboard-header h2 span {
          color: var(--accent);
          font-style: italic;
          font-family: var(--font-display);
        }

        .modern-3d-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 32px;
          perspective: 1200px;
        }

        .modern-3d-card {
          height: 320px;
          background: transparent;
          border: none;
          cursor: pointer;
        }

        .card-3d-inner {
          position: relative;
          width: 100%;
          height: 100%;
          transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
          transform-style: preserve-3d;
        }

        .modern-3d-card:hover .card-3d-inner {
          transform: rotateY(180deg);
        }

        .card-3d-front,
        .card-3d-back {
          position: absolute;
          width: 100%;
          height: 100%;
          backface-visibility: hidden;
          border-radius: var(--radius-xl);
          padding: 32px;
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: center;
          text-align: center;
          border: 1px solid var(--border);
          box-shadow: var(--shadow-card);
        }

        .card-3d-front {
          background: var(--bg-card);
          color: var(--ink);
        }

        .card-3d-back {
          background: var(--bg-dark);
          color: #fff;
          transform: rotateY(180deg);
        }

        .icon-wrap {
          font-size: 3rem;
          margin-bottom: 20px;
          filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.1));
        }

        .card-3d-front h3 {
          font-family: var(--font-display);
          font-size: 1.5rem;
          margin-bottom: 12px;
        }

        .btn-cta-small {
          margin-top: 20px;
          padding: 8px 24px;
          border-radius: 100px;
          background: var(--accent);
          color: #000;
          font-weight: 700;
          font-size: 0.8rem;
          text-decoration: none;
        }

        .glass-cta {
          background: rgba(255, 255, 255, 0.03);
          backdrop-filter: blur(10px);
          border: 1px solid var(--border);
          padding: 48px;
          border-radius: var(--radius-xl);
          max-width: 800px;
          margin: 0 auto;
        }

        [data-theme="dark"] .card-3d-front {
          background: #1a1a1a;
          border-color: rgba(255, 255, 255, 0.05);
        }

        @media (max-width: 960px) {
          .modern-3d-grid {
            grid-template-columns: 1fr;
          }
        }
      </style>
      <%- include('./partials/script.ejs') %>
        <%- include('./partials/footer.ejs') %>
</body>

</html>