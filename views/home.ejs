<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
    
  </head>
  <body>
     <%- include('./partials/nav.ejs') %>
      <%- include('./partials/slide.ejs') %>
 
    <div class="container my-3">
  <div class="section-label"><span>Latest Posts</span></div>
  <div class="blog-grid">
    <% Blogs.forEach((blog) => { %>
      <div class="card">
        <img src="<%= blog.coverImage %>" class="card-img-top" alt="Blog Image">
        <div class="card-body">
          <h5 class="card-title"><%= blog.title %></h5>
          <p class="card-text"><%= blog.body %></p>
          <a href="/blog/<%= blog._id %>" class="btn btn-primary">Read More</a>
        </div>
      </div>
    <% }) %>
  </div>
</div>
    <%- include('./partials/script.ejs') %>
     <%- include('./partials/footer.ejs') %>
  </body>
</html>
