<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blogify</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,900;1,900&family=DM+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet">
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
    
    
    
      /* ── HERO ──────────────────────────────────────────────── */
      .hero {
        min-height: 100vh;
        background: #f4f1eb;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        position: relative;
        overflow: hidden;
        padding: 90px 24px 72px;
      }
    
      /* ── NAV (overlaid on hero) ─────────────────────────────── */
      .hero-nav {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 40px;
        padding: 26px 40px;
      }
    
      .hero-nav a {
        font-size: 0.9rem;
        font-weight: 500;
        color: #1a1a1a;
        text-decoration: none;
        letter-spacing: 0.01em;
        transition: opacity 0.2s;
      }
    
      .hero-nav a:hover {
        opacity: 0.55;
      }
    
      .hero-nav .brand {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-weight: 900;
        font-size: 1.5rem;
        color: #d42b14;
        letter-spacing: -1px;
      }
    
      /* ── FLOWERS ────────────────────────────────────────────── */
      .flower {
        position: absolute;
        pointer-events: none;
        user-select: none;
        z-index: 1;
      }
    
      .flower-left {
        left: -80px;
        top: 50%;
        transform: translateY(-50%);
        width: 380px;
        animation: bob 6s ease-in-out infinite;
      }
    
      .flower-right {
        right: -90px;
        top: 44%;
        transform: translateY(-50%);
        width: 440px;
        animation: bob 7.5s ease-in-out infinite reverse;
      }
    
      @keyframes bob {
    
        0%,
        100% {
          margin-top: 0;
        }
    
        50% {
          margin-top: -16px;
        }
      }
    
      /* ── HERO CONTENT ───────────────────────────────────────── */
      .hero-inner {
        position: relative;
        z-index: 10;
        max-width: 660px;
      }
    
      .hero-icon {
        width: 52px;
        margin: 0 auto 18px;
      }
    
      .hero-greeting {
        font-size: 1rem;
        font-weight: 500;
        color: #555;
        margin-bottom: 14px;
      }
    
      .hero-title {
        font-family: 'Playfair Display', serif;
        font-weight: 900;
        font-size: clamp(2.8rem, 7vw, 5rem);
        line-height: 1.07;
        color: #1a1a1a;
        letter-spacing: -2px;
        margin-bottom: 24px;
      }
    
      .hero-sub {
        font-size: 1rem;
        font-weight: 400;
        color: #666;
        line-height: 1.72;
        max-width: 420px;
        margin: 0 auto 38px;
      }
    
      .hero-cta {
        display: inline-block;
        background: #1a1a1a;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        padding: 15px 38px;
        border-radius: 999px;
        transition: background 0.2s, transform 0.2s;
      }
    
      .hero-cta:hover {
        background: #3a3a3a;
        transform: translateY(-2px);
      }
    
      /* ── BLOG SECTION ───────────────────────────────────────── */
      .posts-section {
        background: #f4f1eb;
        padding: 60px 24px 80px;
      }
    
      .posts-section .wrap {
        max-width: 1200px;
        margin: 0 auto;
      }
    
      .section-label {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 30px;
      }
    
      .section-label span {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #999;
        white-space: nowrap;
      }
    
      .section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(0, 0, 0, 0.1);
      }
    
      /* ── GRID ───────────────────────────────────────────────── */
      .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }
    
      /* Featured */
      .blog-grid .card:first-child {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: 5fr 7fr;
        min-height: 360px;
        border-radius: 20px;
      }
    
      .blog-grid .card:first-child .card-img-wrapper {
        border-radius: 20px 0 0 20px;
        height: 100%;
      }
    
      .blog-grid .card:first-child .card-img-top {
        height: 100%;
        max-height: 420px;
        border-radius: 0;
      }
    
      .blog-grid .card:first-child .card-body {
        background: #1a1a1a;
        border-radius: 0 20px 20px 0;
        padding: 48px 52px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        gap: 14px;
      }
    
      .blog-grid .card:first-child .card-category {
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.5);
      }
    
      .blog-grid .card:first-child .card-title {
        color: #fff;
        font-size: 2.1rem;
        -webkit-line-clamp: 3;
      }
    
      .blog-grid .card:first-child .card-text {
        color: rgba(255, 255, 255, 0.55);
      }
    
      .blog-grid .card:first-child .btn {
        background: #fff;
        color: #1a1a1a;
      }
    
      .blog-grid .card:first-child .btn:hover {
        background: #f0f0f0;
        color: #1a1a1a;
      }
    
      /* ── CARD ───────────────────────────────────────────────── */
      .card {
        background: #fff;
        border: 1px solid rgba(0, 0, 0, 0.07);
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
        transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s;
      }
    
      .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 14px 38px rgba(0, 0, 0, 0.11);
      }
    
      .card-img-wrapper {
        overflow: hidden;
        border-radius: 18px 18px 0 0;
      }
    
      .card-img-top {
        width: 100%;
        height: 210px;
        object-fit: cover;
        display: block;
        transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
      }
    
      .card:hover .card-img-top {
        transform: scale(1.05);
      }
    
      .card-body {
        padding: 20px 22px 24px;
        display: flex;
        flex-direction: column;
        flex: 1;
        gap: 10px;
      }
    
      .card-category {
        display: inline-flex;
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: #888;
        background: rgba(0, 0, 0, 0.05);
        padding: 3px 10px;
        border-radius: 999px;
        width: fit-content;
      }
    
      .card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.18rem;
        font-weight: 900;
        font-style: italic;
        line-height: 1.25;
        color: #1a1a1a;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
      }
    
      .card-text {
        font-size: 0.84rem;
        color: #777;
        line-height: 1.65;
        flex: 1;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
        overflow: hidden;
      }
    
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        align-self: flex-start;
        margin-top: auto;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        text-decoration: none;
        background: #1a1a1a;
        color: #fff;
        border: none;
        padding: 9px 20px;
        border-radius: 999px;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
      }
    
      .btn:hover {
        background: #333;
        transform: translateY(-1px);
      }
    
      /* ── RESPONSIVE ─────────────────────────────────────────── */
      @media (max-width: 900px) {
        .blog-grid {
          grid-template-columns: repeat(2, 1fr);
        }
    
        .blog-grid .card:first-child {
          grid-column: 1/-1;
        }
    
        .flower-left {
          width: 250px;
          left: -50px;
        }
    
        .flower-right {
          width: 290px;
          right: -60px;
        }
      }
    
      @media (max-width: 640px) {
        .blog-grid {
          grid-template-columns: 1fr;
        }
    
        .blog-grid .card:first-child {
          display: flex;
          flex-direction: column;
          border-radius: 18px;
        }
    
        .blog-grid .card:first-child .card-img-wrapper {
          border-radius: 18px 18px 0 0;
          height: 220px;
        }
    
        .blog-grid .card:first-child .card-img-top {
          height: 220px;
          max-height: 220px;
        }
    
        .blog-grid .card:first-child .card-body {
          border-radius: 0 0 18px 18px;
          padding: 26px 22px;
        }
    
        .blog-grid .card:first-child .card-title {
          font-size: 1.6rem;
        }
    
        .flower-left,
        .flower-right {
          display: none;
        }
    
        .hero-title {
          font-size: 2.5rem;
          letter-spacing: -1px;
        }
    
        .hero-nav {
          gap: 20px;
          padding: 20px 20px;
          flex-wrap: wrap;
        }
      }
    </style>
</head>
<body>
  <section class="hero">
  
    <!-- Blue flower -->
    <svg class="flower flower-left" viewBox="0 0 420 520">
      <g transform="translate(210,280)">
        <ellipse rx="85" ry="115" cy="-120" fill="#a8d8ea" />
        <ellipse rx="85" ry="115" fill="#a8d8ea" transform="rotate(45) translate(0,-120)" />
        <ellipse rx="85" ry="115" fill="#a8d8ea" transform="rotate(90) translate(0,-120)" />
        <ellipse rx="85" ry="115" fill="#a8d8ea" transform="rotate(135) translate(0,-120)" />
        <ellipse rx="85" ry="115" fill="#a8d8ea" transform="rotate(180) translate(0,-120)" />
        <ellipse rx="85" ry="115" fill="#a8d8ea" transform="rotate(225) translate(0,-120)" />
        <ellipse rx="85" ry="115" fill="#a8d8ea" transform="rotate(270) translate(0,-120)" />
        <ellipse rx="85" ry="115" fill="#a8d8ea" transform="rotate(315) translate(0,-120)" />
        <ellipse rx="60" ry="75" fill="#3535b0" />
      </g>
    </svg>
  
    <!-- Red flower -->
    <svg class="flower flower-right" viewBox="0 0 500 580">
      <g transform="translate(250,320)">
        <ellipse rx="100" ry="140" cy="-145" fill="#d42b14" />
        <ellipse rx="100" ry="140" fill="#d42b14" transform="rotate(45) translate(0,-145)" />
        <ellipse rx="100" ry="140" fill="#d42b14" transform="rotate(90) translate(0,-145)" />
        <ellipse rx="100" ry="140" fill="#d42b14" transform="rotate(135) translate(0,-145)" />
        <ellipse rx="100" ry="140" fill="#d42b14" transform="rotate(180) translate(0,-145)" />
        <ellipse rx="100" ry="140" fill="#d42b14" transform="rotate(225) translate(0,-145)" />
        <ellipse rx="100" ry="140" fill="#d42b14" transform="rotate(270) translate(0,-145)" />
        <ellipse rx="100" ry="140" fill="#d42b14" transform="rotate(315) translate(0,-145)" />
        <ellipse rx="68" ry="88" fill="#fff" />
      </g>
    </svg>
  
    <!-- Content -->
    <div class="hero-inner">
  
      <svg class="hero-icon" viewBox="0 0 80 46">
        <path d="M5 42 Q5 5 40 5 Q75 5 75 42" fill="none" stroke="#d42b14" stroke-width="5.5" />
        <path d="M13 42 Q13 14 40 14 Q67 14 67 42" fill="none" stroke="#f0a22a" stroke-width="5" />
        <path d="M22 42 Q22 22 40 22 Q58 22 58 42" fill="none" stroke="#f5d442" stroke-width="4.5" />
        <path d="M31 42 Q31 30 40 30 Q49 30 49 42" fill="none" stroke="#5cc85c" stroke-width="4" />
      </svg>
  
      <p class="hero-greeting">Hi, welcome to Blogify ✦</p>
  
      <h1 class="hero-title">
        Stories and<br>ideas you can<br>count on
      </h1>
  
      <p class="hero-sub">
        Simplicity is our superpower. We turn complex ideas into
        reads you'll love — for creators, builders, and curious minds.
      </p>
  
      <a href="/blog" class="hero-cta">Explore all blogs</a>
  
    </div>
  
  </section>
</body>
</html>


