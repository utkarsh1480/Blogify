<!-- ── BLOGIFY HERO ─────────────────────────────────────────── -->
<section class="blogify-hero">
  <div class="hero-glow hero-glow-1"></div>
  <div class="hero-glow hero-glow-2"></div>

  <div class="blogify-hero-inner">
    <span class="hero-chip anim-fade-up" style="--delay:.1s">✦ Welcome to Blogify</span>

    <h1 class="blogify-hero-title anim-fade-up" style="--delay:.2s">
      Share your <em>stories</em>,<br>inspire the <em>world</em>.
    </h1>

    <p class="blogify-hero-sub anim-fade-up" style="--delay:.35s">
      Blogify is your creative space to write, publish, and discover
      blogs from creators everywhere. Beautiful writing starts here.
    </p>

    <div class="hero-actions anim-fade-up" style="--delay:.5s">
      <a href="/explore" class="hero-btn-primary">Explore Blogs</a>
      <% if (!locals.User) { %>
        <a href="/signup" class="hero-btn-outline">Get Started — Free</a>
        <% } else { %>
          <a href="/blog" class="hero-btn-outline">Write a Blog</a>
          <% } %>
    </div>
  </div>

  <!-- How it works -->
  <div class="how-it-works anim-fade-up" style="--delay:.65s">
    <h2 class="hiw-title">How it works</h2>
    <div class="hiw-grid">
      <div class="hiw-step">
        <div class="hiw-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </div>
        <span class="hiw-num">01</span>
        <h3>Create Account</h3>
        <p>Sign up for free in seconds and join our community of writers.</p>
      </div>
      <div class="hiw-step">
        <div class="hiw-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9" />
            <path
              d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z" />
          </svg>
        </div>
        <span class="hiw-num">02</span>
        <h3>Write Your Blog</h3>
        <p>Add a title, body, and a cover image. Your story, your way.</p>
      </div>
      <div class="hiw-step">
        <div class="hiw-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
            <polyline points="16 6 12 2 8 6" />
            <line x1="12" x2="12" y1="2" y2="15" />
          </svg>
        </div>
        <span class="hiw-num">03</span>
        <h3>Publish & Share</h3>
        <p>Publish instantly. Your blog goes live for the entire world to read.</p>
      </div>
    </div>
  </div>
</section>