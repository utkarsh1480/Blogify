<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
  </head>
  <body>
    <%- include('./partials/nav.ejs') %>

    <!-- Profile Header -->
    <section class="profile-header">
      <div class="profile-header-inner">
        <div class="profile-avatar-wrapper">
          <img src="<%= (User.profileImgUrl && !User.profileImgUrl.startsWith('images/')) ? User.profileImgUrl : 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + User.first_name %>" alt="<%= User.first_name %>" class="profile-avatar-large">
        </div>
        <h1 class="profile-name"><%= User.first_name %> <%= User.last_name || '' %></h1>
        <p class="profile-email"><%= User.email %></p>
        <div class="profile-stats">
          <div class="stat-item">
            <span class="stat-value"><%= Blogs.length %></span>
            <span class="stat-label">Blogs Created</span>
          </div>
        </div>
      </div>
    </section>

    <!-- User's Blogs -->
    <div class="container my-5">
      <div class="section-label"><span>Your Stories</span></div>
      
      <% if (Blogs.length === 0) { %>
        <div class="explore-empty">
          <div class="explore-empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4Z"/></svg>
          </div>
          <h3>You haven't written any blogs yet</h3>
          <p>Start sharing your thoughts with the world today.</p>
          <a href="/blog" class="btn btn-primary">Create Your First Blog</a>
        </div>
      <% } else { %>
        <div class="blog-grid profile-grid">
          <% Blogs.forEach((blog) => { %>
            <div class="card profile-blog-card">
              <% if (blog.coverImage) { %>
                <img src="<%= blog.coverImage %>" class="card-img-top" alt="<%= blog.title %>">
              <% } else { %>
                <div class="card-img-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
              <% } %>
              <div class="card-body">
                <h5 class="card-title"><%= blog.title %></h5>
                <p class="card-text"><%= blog.body %></p>
                
                <div class="card-actions mb-3 d-flex gap-2">
                  <a href="/blog/edit/<%= blog._id %>" class="btn-action btn-edit" title="Edit Blog">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    Edit
                  </a>
                  <a href="/blog/delete/<%= blog._id %>" class="btn-action btn-delete" title="Delete Blog" onclick="return confirm('Are you sure you want to delete this blog?')">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                    Delete
                  </a>
                </div>

                <div class="card-footer-meta">
                  <span class="blog-date"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  <a href="/blog/<%= blog._id %>" class="read-link">Read Story →</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <%- include('./partials/footer.ejs') %>
    <%- include('./partials/script.ejs') %>
  </body>
</html>
